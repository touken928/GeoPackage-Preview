{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2020",
    "outDir": "out",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "moduleResolution": "node16"
  },
  "include": ["src/extension.ts", "src/preview/**/*", "src/shared/**/*", "src/util/**/*"],
  "exclude": ["node_modules", "out"]
}
